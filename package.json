{
  "name": "flipdeck",
  "version": "1.0.0",
  "private": true,
  "description": "FlipDeck — TCG price-tracking & arbitrage platform (Magic, Riftbound, Yu-Gi-Oh!, Pokémon, Lorcana).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "setup": "prisma generate && prisma db push --skip-generate && tsx prisma/seed.ts",
    "worker": "tsx src/lib/worker/run.ts",
    "worker:once": "tsx src/lib/worker/run.ts --once",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.18.0",
    "clsx": "2.1.1",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "web-push": "3.6.7",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.15",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@types/web-push": "3.6.3",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "8.4.41",
    "prisma": "5.18.0",
    "tailwindcss": "3.4.10",
    "tsx": "4.17.0",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
