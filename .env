# ─────────────────────────────────────────────────────────────────────────────
# FlipDeck dev environment. Committed on purpose (no real secrets) so the demo
# runs immediately after clone. Put real/production secrets in .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# Database. SQLite by default (zero external services). To use Postgres:
#   1. set DATABASE_URL to your postgres connection string
#   2. change datasource `provider` to "postgresql" in prisma/schema.prisma
#   3. run `npm run db:push`
DATABASE_URL="file:./dev.db"

# Session signing secret. CHANGE THIS in production.
SESSION_SECRET="flipdeck-dev-secret-change-me-in-production-0123456789"

# Public base URL (used for magic-link + notification deep links).
APP_URL="http://localhost:3000"

# ── Price providers ──────────────────────────────────────────────────────────
# When a game's provider env flag is unset, FlipDeck uses the MOCK provider so
# everything works without API keys. Flip these on to use real data sources.
PRICE_PROVIDER_MTG="mock"          # mock | scryfall
PRICE_PROVIDER_POKEMON="mock"      # mock | pokemontcg
PRICE_PROVIDER_YUGIOH="mock"       # mock | ygoprodeck
PRICE_PROVIDER_LORCANA="mock"      # mock | lorcast
PRICE_PROVIDER_RIFTBOUND="mock"    # mock  (no reliable public API yet)

POKEMONTCG_API_KEY=""              # optional; pokemontcg.io works keyless at a lower rate limit

# ── Web Push (optional) ──────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# When unset, notifications use the console/log adapter (dev-safe).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:dev@flipdeck.local"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email (optional; magic-link delivery) ────────────────────────────────────
# When unset, magic-link URLs are printed to the server console (dev).
SMTP_URL=""
EMAIL_FROM="FlipDeck <no-reply@flipdeck.local>"

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_TICK_MS="60000"             # base ingest cadence in the loop runner
